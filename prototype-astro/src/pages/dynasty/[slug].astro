---
import { dynasties } from '../../data/dynasties';

export function getStaticPaths() {
  return dynasties.map((dynasty) => ({
    params: { slug: dynasty.slug },
    props: { slug: dynasty.slug },
  }));
}

const { slug } = Astro.props;
// Redirect old URL to default (zh) bilingual route
return Astro.redirect(`${import.meta.env.BASE_URL}zh/dynasty/${slug}`, 301);
---
