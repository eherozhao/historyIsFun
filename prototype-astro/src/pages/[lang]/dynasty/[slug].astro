---
import Layout from '../../../layouts/Layout.astro';
import { dynasties } from '@/data/dynasties';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allEntries = await getCollection('dynasty');

  return dynasties.flatMap((dynasty) => {
    return (['zh', 'en'] as const).map((lang) => {
      const entry = allEntries.find(
        (e) => e.data.dynastySlug === dynasty.slug && e.data.lang === lang
      );
      return {
        params: { lang, slug: dynasty.slug },
        props: { dynasty, entry: entry ?? null },
      };
    });
  });
}

const { lang, slug } = Astro.params;
const { dynasty, entry } = Astro.props;

const currentIndex = dynasties.findIndex((d) => d.slug === dynasty.slug);
const prev = currentIndex > 0 ? dynasties[currentIndex - 1] : null;
const next = currentIndex < dynasties.length - 1 ? dynasties[currentIndex + 1] : null;

const otherLang = lang === 'zh' ? 'en' : 'zh';
const otherLangLabel = lang === 'zh' ? 'English' : '中文';

const rendered = entry ? await entry.render() : null;
const Content = rendered?.Content;

const figures      = entry?.data.figures      ?? [];
const events       = entry?.data.events       ?? [];
const achievements = entry?.data.achievements ?? null;
const references   = entry?.data.references   ?? null;

const isZh = lang === 'zh';
const L = {
  overview:   isZh ? '简介'   : 'Overview',
  figures:    isZh ? '重要人物' : 'Key Figures',
  events:     isZh ? '重大事件' : 'Key Events',
  culture:    isZh ? '文化成就' : 'Cultural Achievements',
  economy:    isZh ? '经济'   : 'Economy',
  politics:   isZh ? '政治'   : 'Politics',
  cultureSub: isZh ? '文化'   : 'Culture',
  artifact:   isZh ? '文物'   : 'Artifact',
  museum:     isZh ? '馆藏'   : 'Collection',
  artifacts:  isZh ? '重点文物' : 'Featured Artifacts',
  back:       isZh ? '回到卷轴' : 'Back to Timeline',
  prev:       isZh ? '上一朝'  : 'Previous',
  next:       isZh ? '下一朝'  : 'Next',
  comingSoon: isZh ? '内容正在整理中，敬请期待。' : 'Content coming soon.',
};

const figuresJson = JSON.stringify(figures);
const eventsJson  = JSON.stringify(events);

// Collect all artifacts with museum info from achievements for the gallery
const allArtifacts = achievements
  ? [achievements.economy, achievements.politics, achievements.culture]
      .flat()
      .filter((item): item is NonNullable<typeof item> => !!item?.artifact)
      .map(item => ({ title: item.title, artifact: item.artifact!, museum: item.museum, image: item.image }))
  : [];

const artifactsJson = JSON.stringify(allArtifacts);
---

<Layout title={`${dynasty.name} ${dynasty.englishName} | 华夏春秋`} lang={lang}>

  <!-- ── HERO ── -->
  <section class="bg-night relative overflow-hidden">

    {/* Artwork: use <img> for reliable rendering */}
    {dynasty.artwork && (
      <img src={`${import.meta.env.BASE_URL}${dynasty.artwork}`}
           alt="" aria-hidden="true"
           class="absolute inset-0 w-full h-full object-cover pointer-events-none"
           style={`opacity: 0.38; filter: saturate(0.7); object-position: ${dynasty.artworkPosition ?? 'center center'};`} />
    )}

    {/* Hero-to-content transition — TESTING: hard cut (no gradient) */}

    <div class="relative z-10 max-w-2xl mx-auto px-6 py-20 sm:py-28 text-center">
      <div class="w-8 h-px mx-auto mb-8" style={`background-color: ${dynasty.color}; opacity: 0.5;`}></div>

      <h1 class="font-heading text-7xl sm:text-9xl text-scroll tracking-wider mb-4">
        {dynasty.name}
      </h1>
      <p class="font-body text-scroll/50 text-xl tracking-[0.2em]">{dynasty.englishName}</p>

      <div class="w-10 h-px bg-gold/20 mx-auto my-8"></div>

      <p class="text-gold-light/70 text-3xl font-heading tracking-wider">{dynasty.period}</p>

      <div class="mt-8 flex items-center justify-center gap-3">
        <span class="text-scroll/60 text-lg tracking-widest">{lang === 'zh' ? '中文' : 'English'}</span>
        <span class="text-scroll/25 text-lg">|</span>
        <a href={`${import.meta.env.BASE_URL}${otherLang}/dynasty/${slug}`}
           class="text-gold/60 hover:text-gold transition-colors text-lg tracking-widest">
          {otherLangLabel}
        </a>
      </div>
    </div>
  </section>

  <!-- ── CONTENT — single centred column, sidebar lives outside this flow ── -->
  <section class="scroll-surface relative">
    <div class="max-w-2xl mx-auto px-6 py-16 sm:py-20">

      <!-- 简介 -->
      <div class="mb-16">
        <h2 class="section-heading">
          {L.overview}
          <span class="section-heading-en">Overview</span>
        </h2>
        {Content ? (
          <div class="prose-dynasty"><Content /></div>
        ) : (
          <>
            <p class="body-text">{dynasty.description}</p>
            <p class="mt-6 text-sm text-ink-faint italic">{L.comingSoon}</p>
          </>
        )}
      </div>

      <!-- 重要人物 -->
      {figures.length > 0 && (
        <div class="mb-16 figures-section-wrapper">
          <h2 class="section-heading">
            {L.figures}
            <span class="section-heading-en">Key Figures</span>
          </h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
            {figures.map((figure, i) => (
              <button
                class="figure-card text-left p-4 rounded bg-scroll-dark/40 hover:bg-scroll-dark
                       transition-colors duration-200 group cursor-pointer"
                data-index={i}
              >
                <div class="w-12 h-12 rounded-full flex items-center justify-center mb-3
                            font-heading text-xl text-scroll"
                     style={`background-color: ${dynasty.color}; opacity:0.85;`}>
                  {figure.name[0]}
                </div>
                <p class="body-text font-semibold text-ink group-hover:text-vermillion
                          transition-colors leading-snug">
                  {figure.name}
                </p>
                {figure.englishName && (
                  <p class="body-text-sm mt-0.5">{figure.englishName}</p>
                )}
                <p class="body-text-sm mt-1">{figure.role}</p>
                {figure.years && (
                  <p class="text-sm text-gold/60 mt-1">{figure.years}</p>
                )}
              </button>
            ))}
          </div>
          <!-- Detail sidebar anchored to this section -->
          <aside id="detail-sidebar"
                 class="detail-sidebar"
                 style="display:none"
                 aria-live="polite">
            <div class="flex items-center justify-between px-5 py-3 border-b border-gold/10">
              <span id="sidebar-tag" class="text-xs text-gold/60 tracking-widest uppercase"></span>
              <button id="sidebar-close"
                      class="text-ink-faint hover:text-vermillion transition-colors p-1 cursor-pointer text-sm leading-none">
                ✕
              </button>
            </div>
            <div id="sidebar-body" class="px-5 py-5"></div>
          </aside>
        </div>
      )}

      <!-- 重大事件 -->
      {events.length > 0 && (
        <div class="mb-16">
          <h2 class="section-heading">
            {L.events}
            <span class="section-heading-en">Key Events</span>
          </h2>
          <div class="relative pl-6 border-l border-gold/20">
            {events.map((event, i) => (
              <div class="event-wrapper mb-7">
                <button
                  class="event-card w-full text-left group cursor-pointer relative"
                  data-index={i}
                >
                  <div class="absolute -left-[29px] w-3 h-3 rounded-full border-2
                              border-gold/40 bg-scroll group-hover:border-vermillion
                              group-hover:bg-vermillion/20 transition-colors mt-1.5"></div>
                  <p class="body-text-sm text-gold/70 tracking-widest mb-1">{event.year}</p>
                  <p class="event-name body-text font-semibold text-ink group-hover:text-vermillion
                            transition-colors">
                    {event.name}
                  </p>
                  {event.englishName && (
                    <p class="body-text-sm text-ink-faint mt-0.5">{event.englishName}</p>
                  )}
                </button>
                <div class="inline-detail event-detail">
                  <div class="inline-detail-inner"></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- 文化成就 -->
      {achievements && (
        <div class="mb-16">
          <h2 class="section-heading">
            {L.culture}
            <span class="section-heading-en">Cultural Achievements</span>
          </h2>
          {[
            { label: L.economy,    items: achievements.economy },
            { label: L.politics,   items: achievements.politics },
            { label: L.cultureSub, items: achievements.culture },
          ].filter(s => s.items?.length).map(section => (
            <details class="mb-4 group" open>
              <summary class="flex items-center gap-2 cursor-pointer list-none py-3
                              border-b border-gold/15 select-none">
                <span class="text-gold/60 text-xs transition-transform duration-200
                             group-open:rotate-90">▶</span>
                <span class="body-text font-semibold text-ink">{section.label}</span>
              </summary>
              <div class="pt-4 space-y-6">
                {section.items!.map(item => (
                  <div class="pl-4 border-l border-gold/15">
                    <p class="body-text font-semibold text-ink mb-1">{item.title}</p>
                    <p class="body-text text-ink-light leading-[1.85]">{item.description}</p>
                    {(item.artifact || item.museum) && (
                      <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1">
                        {item.artifact && (
                          <span class="body-text-sm text-ink-faint">
                            <span class="text-gold/50">{L.artifact}：</span>{item.artifact}
                          </span>
                        )}
                        {item.museum && (
                          <span class="body-text-sm text-ink-faint">
                            <span class="text-gold/50">{L.museum}：</span>{item.museum}
                          </span>
                        )}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </details>
          ))}

          <!-- 重点文物 Gallery -->
          {allArtifacts.length > 0 && (
            <div class="mt-10 pt-8 border-t border-gold/15">
              <h3 class="body-text font-semibold text-ink mb-5 flex items-baseline gap-2">
                {L.artifacts}
                <span class="text-xs font-normal text-ink-faint tracking-wider">Featured Artifacts</span>
              </h3>
              <div class="grid grid-cols-2 gap-4">
                {allArtifacts.map((a, i) => (
                  <button class="artifact-card rounded overflow-hidden border border-gold/12 bg-scroll-dark/30
                                 cursor-pointer text-left hover:border-gold/25 transition-colors"
                          data-artifact-index={i}>
                    <div class="artifact-placeholder">
                      <span class="artifact-placeholder-text">{a.artifact}</span>
                    </div>
                    <div class="p-3">
                      <p class="body-text-sm font-semibold text-ink leading-snug">{a.artifact}</p>
                      <p class="text-xs text-ink-faint mt-0.5 leading-relaxed">{a.title}</p>
                      {a.museum && (
                        <p class="text-xs text-gold/60 mt-1.5 flex items-start gap-1">
                          <span class="shrink-0">📍</span>
                          <span>{a.museum}</span>
                        </p>
                      )}
                    </div>
                  </button>
                ))}
              </div>
            </div>
          )}
        </div>
      )}

      <!-- Skeleton for dynasties without structured content -->
      {figures.length === 0 && events.length === 0 && !achievements && (
        <div class="grid sm:grid-cols-2 gap-8 mb-14">
          <div>
            <h3 class="font-heading text-lg text-ink mb-4">{L.figures}</h3>
            <div class="space-y-4 mt-4">
              {[1,2,3].map(() => (
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-scroll-dark"></div>
                  <div class="flex-1">
                    <div class="h-2.5 bg-scroll-dark rounded w-20"></div>
                    <div class="h-2 bg-scroll-dark/60 rounded w-28 mt-2"></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div>
            <h3 class="font-heading text-lg text-ink mb-4">{L.events}</h3>
            <div class="space-y-4 mt-4">
              {[1,2,3].map(() => (
                <div class="flex items-center gap-3">
                  <div class="w-1.5 h-1.5 rounded-full bg-gold/30"></div>
                  <div class="flex-1">
                    <div class="h-2.5 bg-scroll-dark rounded w-24"></div>
                    <div class="h-2 bg-scroll-dark/60 rounded w-full mt-2"></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      )}

      <!-- 参考资料 -->
      {references && (
        <div class="mb-16 pt-10 border-t border-gold/10">
          <h2 class="text-xs font-body font-semibold tracking-[0.12em] uppercase
                     text-ink-faint mb-5">
            {isZh ? '参考资料' : 'References'}
          </h2>
          {references.primary && references.primary.length > 0 && (
            <div class="mb-4">
              <p class="text-xs text-gold/50 tracking-widest uppercase mb-2">
                {isZh ? '原始文献' : 'Primary Sources'}
              </p>
              <ul class="space-y-1.5">
                {references.primary.map(r => (
                  <li class="text-xs text-ink-faint leading-relaxed"
                      set:html={r.replace(/\*(.*?)\*/g, '<em>$1</em>')} />
                ))}
              </ul>
            </div>
          )}
          {references.secondary && references.secondary.length > 0 && (
            <div>
              <p class="text-xs text-gold/50 tracking-widest uppercase mb-2">
                {isZh ? '现代学术著作' : 'Secondary Scholarship'}
              </p>
              <ul class="space-y-1.5">
                {references.secondary.map(r => (
                  <li class="text-xs text-ink-faint leading-relaxed"
                      set:html={r.replace(/\*(.*?)\*/g, '<em>$1</em>')} />
                ))}
              </ul>
            </div>
          )}
        </div>
      )}

      <!-- Prev / Next -->
      <nav class="flex items-center justify-between pt-10 border-t border-gold/15 mt-10">
        {prev ? (
          <a href={`${import.meta.env.BASE_URL}${lang}/dynasty/${prev.slug}`}
             class="flex items-center gap-3 text-ink-light hover:text-vermillion transition-colors group">
            <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform duration-300"
                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/>
            </svg>
            <div class="text-right">
              <p class="text-xs text-ink-faint tracking-wider uppercase">{L.prev}</p>
              <p class="font-heading text-base mt-0.5">{prev.name}</p>
            </div>
          </a>
        ) : <div />}

        <a href={`${import.meta.env.BASE_URL}#${dynasty.slug}`}
           class="body-text-sm text-ink-faint hover:text-vermillion transition-colors tracking-[0.2em] uppercase">
          {L.back}
        </a>

        {next ? (
          <a href={`${import.meta.env.BASE_URL}${lang}/dynasty/${next.slug}`}
             class="flex items-center gap-3 text-ink-light hover:text-vermillion transition-colors group">
            <div>
              <p class="text-xs text-ink-faint tracking-wider uppercase">{L.next}</p>
              <p class="font-heading text-base mt-0.5">{next.name}</p>
            </div>
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300"
                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        ) : <div />}
      </nav>

    </div><!-- /max-w-2xl -->
  </section>

  <!-- Mobile bottom sheet (< 1280px) -->
  <div id="panel-backdrop"
       class="fixed inset-0 z-30 bg-black/40 transition-opacity duration-300 opacity-0 pointer-events-none"
       style="display:none"></div>

  <aside id="detail-panel"
         class="fixed z-40 bg-[#f2e8d5] shadow-2xl overflow-y-auto
                transition-all duration-300 panel-hidden"
         style="display:none"
         aria-live="polite">
    <div class="flex items-center justify-between px-5 py-4 border-b border-gold/10">
      <span id="panel-tag" class="text-xs text-gold/60 tracking-widest uppercase"></span>
      <button id="panel-close"
              class="text-ink-faint hover:text-vermillion transition-colors p-2 cursor-pointer text-base leading-none">
        ✕
      </button>
    </div>
    <div id="panel-body" class="px-5 py-5 pb-8"></div>
  </aside>

  <!-- Artifact lightbox -->
  <div id="artifact-lightbox" class="artifact-lightbox" style="display:none">
    <div class="artifact-lightbox-backdrop"></div>
    <div class="artifact-lightbox-content">
      <button id="lightbox-close" class="artifact-lightbox-close">✕</button>
      <div class="artifact-lightbox-image">
        <span id="lightbox-placeholder-text" class="artifact-lightbox-placeholder-text"></span>
      </div>
      <div class="artifact-lightbox-info">
        <p id="lightbox-name" class="font-semibold text-ink text-lg"></p>
        <p id="lightbox-title" class="text-ink-faint text-sm mt-1"></p>
        <p id="lightbox-museum" class="text-gold/70 text-sm mt-2"></p>
      </div>
    </div>
  </div>

</Layout>

<style>
  /* Figures section: relative container for the sidebar */
  .figures-section-wrapper {
    position: relative;
  }

  /* Desktop detail sidebar — absolute within figures section, in the right gutter */
  .detail-sidebar {
    position: absolute;
    top: 0;
    left: 100%;
    margin-left: 1.5rem;
    width: 18rem;
    max-height: 100%;
    overflow-y: auto;
    z-index: 20;
    background: #f2e8d5;
    border: 1px solid rgba(166, 124, 61, 0.12);
    border-radius: 0.75rem;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  /* Mobile bottom sheet */
  #detail-panel {
    left: 0; right: 0; bottom: 0;
    max-height: 72vh;
    border-radius: 1.25rem 1.25rem 0 0;
    border: 1px solid rgba(166,124,61,0.15);
    border-bottom: none;
  }
  #detail-panel.panel-hidden  { transform: translateY(100%); opacity: 0; pointer-events: none; }
  #detail-panel.panel-visible { transform: translateY(0);    opacity: 1; pointer-events: auto; }

  /* Inline expand for events */
  .inline-detail {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.35s ease, opacity 0.3s ease, margin 0.35s ease;
    margin-top: 0;
  }
  .inline-detail.open {
    max-height: 600px;
    opacity: 1;
    margin-top: 0.75rem;
  }
  .inline-detail-inner {
    padding: 1rem 1.25rem;
    border-left: 2px solid rgba(166, 124, 61, 0.3);
    background: rgba(230, 213, 184, 0.5);
    border-radius: 0 0.5rem 0.5rem 0;
  }

  /* Artifact gallery placeholder */
  .artifact-placeholder {
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, #e6d5b8 0%, #d9c9a8 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .artifact-placeholder-text {
    font-family: Georgia, "Noto Serif SC", serif;
    font-size: 0.85rem;
    color: rgba(166, 124, 61, 0.4);
    text-align: center;
    line-height: 1.5;
  }

  /* Artifact lightbox */
  .artifact-lightbox {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .artifact-lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
  }
  .artifact-lightbox-content {
    position: relative;
    max-width: 36rem;
    width: 90vw;
    background: #f2e8d5;
    border-radius: 0.75rem;
    overflow: hidden;
    animation: lightboxIn 0.25s ease;
  }
  .artifact-lightbox-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 10;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(242, 232, 213, 0.9);
    border: 1px solid rgba(166, 124, 61, 0.15);
    color: #6a5a48;
    cursor: pointer;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s;
  }
  .artifact-lightbox-close:hover { color: #bf3b2c; }
  .artifact-lightbox-image {
    aspect-ratio: 3 / 2;
    background: linear-gradient(135deg, #e6d5b8 0%, #d9c9a8 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }
  .artifact-lightbox-placeholder-text {
    font-family: Georgia, "Noto Serif SC", serif;
    font-size: 1.25rem;
    color: rgba(166, 124, 61, 0.35);
    text-align: center;
    line-height: 1.6;
  }
  .artifact-lightbox-info {
    padding: 1.25rem 1.5rem 1.5rem;
  }
  @keyframes lightboxIn {
    from { opacity: 0; transform: scale(0.95); }
    to   { opacity: 1; transform: scale(1); }
  }

  /* Section headings */
  .section-heading {
    font-family: Georgia, "Noto Serif SC", serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: #2c2418;
    margin-bottom: 1.5rem;
    border-left: 2px solid #a67c3d;
    padding-left: 1rem;
    letter-spacing: 0.01em;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }
  .section-heading-en {
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    color: #8a7a68;
    letter-spacing: 0.05em;
  }

  .body-text {
    font-family: system-ui, -apple-system, "Noto Serif SC", sans-serif;
    font-size: 1rem;
    color: #3a2f1e;
    line-height: 1.85;
  }
  .body-text-sm {
    font-family: system-ui, -apple-system, "Noto Serif SC", sans-serif;
    font-size: 0.875rem;
    color: #6a5a48;
    line-height: 1.7;
  }
</style>

  <script type="application/json" id="dynasty-data" set:html={JSON.stringify({
    figures, events, artifacts: allArtifacts, dynastyColor: dynasty.color
  })} />
  <script>
  const _data = JSON.parse(document.getElementById('dynasty-data').textContent);
  const figures = _data.figures;
  const events  = _data.events;
  const artifacts = _data.artifacts;
  const dynastyColor = _data.dynastyColor;

  // Desktop sidebar (wide screens only)
  const sidebar     = document.getElementById('detail-sidebar');
  const sidebarTag  = document.getElementById('sidebar-tag');
  const sidebarBody = document.getElementById('sidebar-body');
  const sidebarClose = document.getElementById('sidebar-close');

  // Mobile bottom-sheet
  const panel     = document.getElementById('detail-panel');
  const backdrop  = document.getElementById('panel-backdrop');
  const panelTag  = document.getElementById('panel-tag');
  const panelBody = document.getElementById('panel-body');
  const panelClose = document.getElementById('panel-close');

  // Wide enough for sidebar to fit in the right gutter?
  const usesSidebar = () => window.innerWidth >= 1280;

  function detailHTML(type, data) {
    if (type === 'figure') {
      const f = data;
      return `
        <div style="width:3.5rem;height:3.5rem;border-radius:50%;display:flex;
                    align-items:center;justify-content:center;margin-bottom:1rem;
                    font-family:Georgia,serif;font-size:1.5rem;color:#fff;font-weight:700;
                    background-color:${dynastyColor};">${f.name[0]}</div>
        <p style="font-family:system-ui,sans-serif;font-size:1.05rem;font-weight:600;
                  color:#2c2418;margin-bottom:0.2rem;">${f.name}</p>
        ${f.englishName ? `<p style="font-size:0.8rem;color:#8a7a68;margin-bottom:0.2rem;">${f.englishName}</p>` : ''}
        <p style="font-size:0.8rem;color:#6a5a48;margin-bottom:0.2rem;">${f.role}</p>
        ${f.years ? `<p style="font-size:0.75rem;color:#a67c3d;margin-bottom:1rem;">${f.years}</p>` : '<div style="margin-bottom:1rem;"></div>'}
        <div style="width:2rem;height:1px;background:#a67c3d;opacity:0.4;margin-bottom:1rem;"></div>
        <p style="font-family:system-ui,sans-serif;font-size:0.875rem;color:#5a4a35;line-height:1.85;">${f.bio}</p>
      `;
    } else {
      const ev = data;
      return `
        <p style="font-size:0.75rem;color:#a67c3d;letter-spacing:0.08em;margin-bottom:0.5rem;">${ev.year}</p>
        <p style="font-family:system-ui,sans-serif;font-size:1.05rem;font-weight:600;
                  color:#2c2418;margin-bottom:0.2rem;">${ev.name}</p>
        ${ev.englishName ? `<p style="font-size:0.8rem;color:#8a7a68;margin-bottom:1rem;">${ev.englishName}</p>` : '<div style="margin-bottom:1rem;"></div>'}
        <div style="width:2rem;height:1px;background:#a67c3d;opacity:0.4;margin-bottom:1rem;"></div>
        <p style="font-family:system-ui,sans-serif;font-size:0.875rem;color:#5a4a35;line-height:1.85;">${ev.description}</p>
      `;
    }
  }

  function showPanel(tag, html) {
    if (!panel || !panelTag || !panelBody) return;
    panelTag.textContent = tag;
    panelBody.innerHTML  = html;
    panel.style.display = 'block';
    if (backdrop) backdrop.style.display = 'block';
    panel.offsetHeight;
    panel.classList.remove('panel-hidden');
    panel.classList.add('panel-visible');
    if (backdrop) {
      backdrop.classList.remove('opacity-0', 'pointer-events-none');
      backdrop.classList.add('opacity-100', 'pointer-events-auto');
    }
  }

  function showDetail(tag, html) {
    if (usesSidebar()) {
      if (!sidebar || !sidebarTag || !sidebarBody) return;
      sidebarTag.textContent = tag;
      sidebarBody.innerHTML  = html;
      sidebar.style.display = 'block';
    } else {
      showPanel(tag, html);
    }
  }

  function hideSidebar() {
    if (sidebar) sidebar.style.display = 'none';
  }

  function hidePanel() {
    if (!panel) return;
    panel.classList.remove('panel-visible');
    panel.classList.add('panel-hidden');
    if (backdrop) {
      backdrop.classList.add('opacity-0', 'pointer-events-none');
      backdrop.classList.remove('opacity-100', 'pointer-events-auto');
    }
    setTimeout(() => {
      panel.style.display = 'none';
      if (backdrop) backdrop.style.display = 'none';
    }, 300);
  }

  sidebarClose?.addEventListener('click', hideSidebar);
  panelClose?.addEventListener('click', hidePanel);
  backdrop?.addEventListener('click', hidePanel);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') { hideSidebar(); hidePanel(); }
  });

  document.querySelectorAll('.figure-card').forEach(card => {
    card.addEventListener('click', () => {
      const f = figures[parseInt(card.dataset.index)];
      if (!f) return;
      showDetail('人物 · Figure', detailHTML('figure', f));
    });
  });

  document.querySelectorAll('.event-card').forEach(card => {
    card.addEventListener('click', () => {
      const ev = events[parseInt(card.dataset.index)];
      if (!ev) return;

      if (!usesSidebar()) {
        showPanel('事件 · Event', detailHTML('event', ev));
        return;
      }

      // Desktop: inline expand below the event
      const wrapper = card.closest('.event-wrapper');
      const detail = wrapper.querySelector('.event-detail');
      const inner = detail.querySelector('.inline-detail-inner');

      if (detail.classList.contains('open')) {
        detail.classList.remove('open');
        return;
      }

      document.querySelectorAll('.event-detail.open').forEach(d => d.classList.remove('open'));
      inner.innerHTML = `<p style="font-size:0.875rem;color:#5a4a35;line-height:1.85;">${ev.description}</p>`;
      detail.classList.add('open');
    });
  });
  // Artifact lightbox
  const lightbox = document.getElementById('artifact-lightbox');
  const lbClose = document.getElementById('lightbox-close');
  const lbBackdrop = lightbox?.querySelector('.artifact-lightbox-backdrop');
  const lbName = document.getElementById('lightbox-name');
  const lbTitle = document.getElementById('lightbox-title');
  const lbMuseum = document.getElementById('lightbox-museum');
  const lbPlaceholder = document.getElementById('lightbox-placeholder-text');

  function openLightbox(idx) {
    const a = artifacts[idx];
    if (!a || !lightbox) return;
    if (lbPlaceholder) lbPlaceholder.textContent = a.artifact;
    if (lbName) lbName.textContent = a.artifact;
    if (lbTitle) lbTitle.textContent = a.title;
    if (lbMuseum) lbMuseum.textContent = a.museum ? '📍 ' + a.museum : '';
    lightbox.style.display = 'flex';
  }

  function closeLightbox() {
    if (lightbox) lightbox.style.display = 'none';
  }

  document.querySelectorAll('[data-artifact-index]').forEach(function(card) {
    card.addEventListener('click', function() {
      openLightbox(parseInt(card.getAttribute('data-artifact-index')));
    });
  });

  lbClose?.addEventListener('click', closeLightbox);
  lbBackdrop?.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
</script>
