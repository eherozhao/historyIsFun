---
import Layout from '../../../layouts/Layout.astro';
import { dynasties } from '@/data/dynasties';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allEntries = await getCollection('dynasty');

  return dynasties.flatMap((dynasty) => {
    return (['zh', 'en'] as const).map((lang) => {
      const entry = allEntries.find(
        (e) => e.data.dynastySlug === dynasty.slug && e.data.lang === lang
      );
      return {
        params: { lang, slug: dynasty.slug },
        props: { dynasty, entry: entry ?? null },
      };
    });
  });
}

const { lang, slug } = Astro.params;
const { dynasty, entry } = Astro.props;

const currentIndex = dynasties.findIndex((d) => d.slug === dynasty.slug);
const prev = currentIndex > 0 ? dynasties[currentIndex - 1] : null;
const next = currentIndex < dynasties.length - 1 ? dynasties[currentIndex + 1] : null;

const otherLang = lang === 'zh' ? 'en' : 'zh';
const otherLangLabel = lang === 'zh' ? 'English' : '中文';

const rendered = entry ? await entry.render() : null;
const Content = rendered?.Content;

const isZh = lang === 'zh';
const labels = {
  overview: isZh ? '简介' : 'Overview',
  figures: isZh ? '重要人物' : 'Key Figures',
  events: isZh ? '重大事件' : 'Key Events',
  culture: isZh ? '文化成就' : 'Culture',
  backToTimeline: isZh ? '回到卷轴' : 'Back to Timeline',
  previous: isZh ? '上一朝' : 'Previous',
  next: isZh ? '下一朝' : 'Next',
  noContent: isZh ? '内容正在整理中，敬请期待。' : 'Content coming soon.',
};
---

<Layout title={`${dynasty.name} ${dynasty.englishName} | 华夏春秋`} lang={lang}>
  <section class="bg-night relative">
    <div
      class="absolute inset-0 opacity-[0.03] pointer-events-none"
      style={`background: radial-gradient(ellipse at 50% 30%, ${dynasty.color}, transparent 60%);`}
    ></div>

    <div class="relative z-10 max-w-2xl mx-auto px-6 py-20 sm:py-28 text-center">
      <div class="w-8 h-px mx-auto mb-8" style={`background-color: ${dynasty.color}; opacity: 0.5;`}></div>

      <h1 class="font-heading text-6xl sm:text-8xl text-scroll tracking-wider mb-3">
        {dynasty.name}
      </h1>
      <p class="font-body text-scroll/30 text-sm tracking-[0.25em]">
        {dynasty.englishName}
      </p>

      <div class="w-10 h-px bg-gold/20 mx-auto my-8"></div>

      <p class="text-gold-light/60 text-base font-heading tracking-wider">
        {dynasty.period}
      </p>

      <!-- Language toggle -->
      <div class="mt-8 flex items-center justify-center gap-2">
        <span class="text-scroll/50 text-xs tracking-widest">
          {lang === 'zh' ? '中文' : 'English'}
        </span>
        <span class="text-scroll/20 text-xs">|</span>
        <a
          href={`${import.meta.env.BASE_URL}${otherLang}/dynasty/${slug}`}
          class="text-gold/50 hover:text-gold transition-colors text-xs tracking-widest"
        >
          {otherLangLabel}
        </a>
      </div>
    </div>
  </section>

  <section class="scroll-surface">
    <div class="max-w-2xl mx-auto px-6 py-16 sm:py-20">

      {Content ? (
        <!-- Rendered Markdown content -->
        <div class="prose-dynasty">
          <Content />
        </div>
      ) : (
        <!-- Skeleton / placeholder when no Markdown file exists yet -->
        <div>
          <div class="mb-14">
            <h2 class="font-heading text-xl text-ink mb-5 gold-left-accent">
              {labels.overview}
            </h2>
            <p class="font-body text-ink-light leading-[1.9] text-base">
              {dynasty.description}
            </p>
            {!entry && (
              <p class="mt-6 text-xs text-ink-faint italic">{labels.noContent}</p>
            )}
          </div>

          <div class="grid sm:grid-cols-2 gap-8 mb-14">
            <div>
              <h3 class="font-heading text-lg text-ink mb-4 gold-left-accent">
                {labels.figures}
              </h3>
              <div class="mt-4 space-y-4">
                {[1, 2, 3].map(() => (
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-scroll-dark"></div>
                    <div class="flex-1">
                      <div class="h-2.5 bg-scroll-dark rounded w-20"></div>
                      <div class="h-2 bg-scroll-dark/60 rounded w-28 mt-2"></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div>
              <h3 class="font-heading text-lg text-ink mb-4 gold-left-accent">
                {labels.events}
              </h3>
              <div class="mt-4 space-y-4">
                {[1, 2, 3].map(() => (
                  <div class="flex items-center gap-3">
                    <div class="w-1.5 h-1.5 rounded-full bg-gold/30"></div>
                    <div class="flex-1">
                      <div class="h-2.5 bg-scroll-dark rounded w-24"></div>
                      <div class="h-2 bg-scroll-dark/60 rounded w-full mt-2"></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <div class="mb-14">
            <h3 class="font-heading text-lg text-ink mb-4 gold-left-accent">
              {labels.culture}
            </h3>
            <div class="mt-4 grid grid-cols-3 gap-4">
              {[1, 2, 3].map(() => (
                <div class="aspect-[4/3] bg-scroll-dark rounded"></div>
              ))}
            </div>
          </div>
        </div>
      )}

      <nav class="flex items-center justify-between pt-10 border-t border-gold/15 mt-10">
        {prev ? (
          <a
            href={`${import.meta.env.BASE_URL}${lang}/dynasty/${prev.slug}`}
            class="flex items-center gap-3 text-ink-light hover:text-vermillion transition-colors group"
          >
            <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"></path>
            </svg>
            <div class="text-right">
              <p class="text-[10px] text-ink-faint tracking-wider uppercase">{labels.previous}</p>
              <p class="font-heading text-base mt-0.5">{prev.name}</p>
            </div>
          </a>
        ) : <div />}

        <a
          href={import.meta.env.BASE_URL}
          class="text-ink-faint hover:text-vermillion transition-colors text-xs tracking-[0.2em] uppercase"
        >
          {labels.backToTimeline}
        </a>

        {next ? (
          <a
            href={`${import.meta.env.BASE_URL}${lang}/dynasty/${next.slug}`}
            class="flex items-center gap-3 text-ink-light hover:text-vermillion transition-colors group"
          >
            <div>
              <p class="text-[10px] text-ink-faint tracking-wider uppercase">{labels.next}</p>
              <p class="font-heading text-base mt-0.5">{next.name}</p>
            </div>
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        ) : <div />}
      </nav>
    </div>
  </section>
</Layout>
