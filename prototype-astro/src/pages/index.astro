---
import Layout from '../layouts/Layout.astro';
import { dynasties } from '../data/dynasties';
---

<Layout title="华夏春秋 | Chronicles of China" fullscreen={true}>
  <!-- 千里江山图 background with parallax -->
  <div id="ink-bg" aria-hidden="true" style={`background-image: url(${import.meta.env.BASE_URL}images/dynasties/beisong.jpg)`}></div>

  <!-- Fixed header overlay -->
  <div class="fixed top-0 left-0 right-0 z-50 bg-night/80 backdrop-blur-md border-b border-gold/10">
    <div class="flex items-center justify-between px-6 h-11">
      <span class="font-heading text-sm tracking-widest text-scroll/80">华夏春秋</span>
      <div class="flex items-center gap-4">
        <span id="current-era" class="text-[10px] text-gold-light/60 tracking-widest uppercase transition-opacity duration-500 cursor-pointer hover:text-gold-light/90 relative select-none flex items-center gap-1">
          <span id="current-era-text"></span>
          <svg class="w-2.5 h-2.5 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </span>
        <!-- Dynasty dropdown -->
        <div id="era-dropdown" class="era-dropdown" style="display:none">
          {dynasties.map((d) => (
            <button class="era-dropdown-item" data-slug={d.slug} data-era={d.englishName}>
              <span class="era-dot" style={`background:${d.color};`}></span>
              <span class="era-name-zh">{d.name}</span>
              <span class="era-name-en">{d.englishName}</span>
              <span class="era-period">{d.period}</span>
            </button>
          ))}
        </div>
        <span class="text-[10px] text-scroll/70 tracking-[0.3em] uppercase hidden sm:inline">Scroll to explore</span>
      </div>
    </div>
    <div id="progress-bar" class="scroll-progress w-full" style="transform: scaleX(0);"></div>
  </div>

  <!-- Full-screen horizontal scroll -->
  <div id="scroll-wrapper" class="fixed inset-0 pt-11 z-10 flex items-center">
    <div id="scroll-container" class="scroll-container flex h-[65vh] cursor-grab select-none overflow-x-auto overflow-y-hidden">

      <!-- Left spacing -->
      <div class="flex-shrink-0 w-[15vw] flex items-center justify-end pr-2">
        <div class="text-scroll/10 text-[10px] tracking-widest uppercase transform -rotate-90 whitespace-nowrap">
          Begin
        </div>
      </div>

      <!-- Left roller -->
      <div class="scroll-roller"></div>

      <!-- Scroll surface -->
      <div id="scroll-surface" class="scroll-surface flex items-stretch relative">

        <!-- Opening section -->
        <div class="min-w-[500px] max-w-[500px] flex flex-col items-center justify-center px-12 text-center">
          <p class="text-gold text-sm tracking-[0.6em] uppercase mb-6">Chronicles of China</p>
          <h1 class="font-heading text-6xl sm:text-7xl text-ink tracking-wider mb-4">华夏春秋</h1>
          <div class="w-12 h-px bg-gold/30 mx-auto my-6"></div>
          <p class="font-body text-ink text-lg leading-relaxed max-w-[280px]">
            纵览五千年华夏文明<br/>从上古传说到现代中国
          </p>
          <p class="font-body text-ink-light text-base mt-3 tracking-wide">
            Explore 5,000 years of Chinese civilization
          </p>
          <div class="mt-10 flex items-center gap-2 text-ink-light text-sm tracking-wider animate-pulse">
            <span>&larr;</span>
            <span>拖动卷轴</span>
            <span>&rarr;</span>
          </div>
        </div>

        <!-- Timeline thread -->
        <div class="absolute left-0 right-0 top-1/2 timeline-thread pointer-events-none z-0"></div>

        <!-- Dynasty sections -->
        {dynasties.map((dynasty, index) => (
          <div
            class="dynasty-section scroll-reveal group relative z-10"
            data-era={dynasty.englishName}
            data-slug={dynasty.slug}
          >
            <a
              href={`${import.meta.env.BASE_URL}zh/dynasty/${dynasty.slug}`}
              class="block relative"
            >
              <p class="text-ink-light text-sm tracking-widest mb-3">{dynasty.period}</p>

              <h2 class="font-display text-4xl text-ink group-hover:text-vermillion transition-colors duration-500 mb-1">
                {dynasty.name}
              </h2>
              <p class="text-ink-light text-base tracking-wider mb-5">{dynasty.englishName}</p>

              <div class="w-8 h-px mb-5 transition-all duration-500"
                   style={`background-color: ${dynasty.color}; opacity: 0.6;`}></div>

              <p class="font-body text-ink text-base leading-[1.9] mb-6">
                {dynasty.description}
              </p>

              <span class="text-sm font-medium text-vermillion group-hover:text-vermillion/70 tracking-widest uppercase transition-colors duration-500">
                探索 &rarr;
              </span>
            </a>

            <div class="absolute top-1/2 left-8 -translate-y-1/2 w-1.5 h-1.5 rounded-full transition-all duration-500 group-hover:scale-[2.5]"
                 style={`background-color: ${dynasty.color}; opacity: 0.5;`}></div>
          </div>
        ))}

        <!-- Closing section -->
        <div class="min-w-[400px] max-w-[400px] flex flex-col items-center justify-center px-12 text-center">
          <div class="w-8 h-px bg-gold/20 mx-auto mb-8"></div>
          <p class="font-heading text-4xl text-ink tracking-wider mb-3">以史为鉴</p>
          <p class="text-ink-light text-base tracking-wider">
            Learn from history, illuminate the future
          </p>
        </div>
      </div>

      <!-- Right roller -->
      <div class="scroll-roller"></div>

      <!-- Right spacing -->
      <div class="flex-shrink-0 w-[15vw] flex items-center pl-2">
        <div class="text-scroll/10 text-[10px] tracking-widest uppercase transform -rotate-90 whitespace-nowrap">
          End
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .era-dropdown {
    position: fixed;
    top: 2.75rem;
    right: 1.5rem;
    width: 18rem;
    max-height: 70vh;
    overflow-y: auto;
    background: rgba(10, 10, 15, 0.95);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(166, 124, 61, 0.15);
    border-radius: 0.5rem;
    padding: 0.35rem 0;
    z-index: 60;
    scrollbar-width: thin;
    scrollbar-color: rgba(166,124,61,0.2) transparent;
  }
  .era-dropdown-item {
    display: grid;
    grid-template-columns: 6px 1fr auto;
    grid-template-rows: auto auto;
    gap: 0 0.5rem;
    align-items: center;
    width: 100%;
    padding: 0.45rem 0.75rem;
    text-align: left;
    cursor: pointer;
    transition: background 0.15s;
    border: none;
    background: none;
    color: inherit;
  }
  .era-dropdown-item:hover, .era-dropdown-item.active {
    background: rgba(166, 124, 61, 0.12);
  }
  .era-dot {
    grid-row: 1 / 3;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    opacity: 0.7;
  }
  .era-name-zh {
    font-size: 0.8rem;
    color: #f2e8d5;
    letter-spacing: 0.05em;
  }
  .era-name-en {
    font-size: 0.6rem;
    color: rgba(166, 124, 61, 0.5);
    text-align: right;
    letter-spacing: 0.04em;
  }
  .era-period {
    grid-column: 2;
    font-size: 0.6rem;
    color: rgba(242, 232, 213, 0.3);
    letter-spacing: 0.03em;
  }
</style>

<script>
  const container = document.getElementById('scroll-container');
  const progressBar = document.getElementById('progress-bar');
  const currentEra = document.getElementById('current-era');
  const inkBg = document.getElementById('ink-bg');

  if (container) {
    let isDown = false;
    let startX: number;
    let scrollLeft: number;
    let dragDistance = 0;

    container.addEventListener('mousedown', (e) => {
      isDown = true;
      dragDistance = 0;
      container.classList.add('cursor-grabbing');
      container.classList.remove('cursor-grab');
      startX = e.pageX - container.offsetLeft;
      scrollLeft = container.scrollLeft;
      e.preventDefault();
    });

    const stopDrag = () => {
      isDown = false;
      container.classList.remove('cursor-grabbing');
      container.classList.add('cursor-grab');
    };

    container.addEventListener('mouseleave', stopDrag);
    container.addEventListener('mouseup', stopDrag);

    container.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      dragDistance++;
      const x = e.pageX - container.offsetLeft;
      const walk = (x - startX) * 1.8;
      container.scrollLeft = scrollLeft - walk;
    });

    container.addEventListener('click', (e) => {
      if (dragDistance > 5) {
        e.preventDefault();
        e.stopPropagation();
      }
    }, true);

    container.addEventListener('wheel', (e) => {
      e.preventDefault();
      const delta = e.deltaY || e.deltaX;
      container.scrollLeft += delta * 1.2;
    }, { passive: false });

    let touchStartX: number;
    let touchScrollLeft: number;
    container.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].pageX;
      touchScrollLeft = container.scrollLeft;
    }, { passive: true });
    container.addEventListener('touchmove', (e) => {
      const x = e.touches[0].pageX;
      container.scrollLeft = touchScrollLeft - (x - touchStartX) * 1.5;
    }, { passive: true });

    container.addEventListener('scroll', () => {
      const maxScroll = container.scrollWidth - container.clientWidth;
      const progress = container.scrollLeft / maxScroll;
      if (progressBar) {
        progressBar.style.transform = `scaleX(${progress})`;
      }
      // Remember scroll position for browser back
      sessionStorage.setItem('scroll-pos', String(container.scrollLeft));
      // Pan the painting left-to-right as the scroll progresses
      if (inkBg) {
        inkBg.style.backgroundPositionX = `${progress * 80}%`;
      }

      const sections = document.querySelectorAll('.dynasty-section');
      const containerRect = container.getBoundingClientRect();
      const center = containerRect.left + containerRect.width / 2;

      let closestSection: Element | null = null;
      let closestDistance = Infinity;

      sections.forEach((section) => {
        const rect = section.getBoundingClientRect();
        const sectionCenter = rect.left + rect.width / 2;
        const distance = Math.abs(sectionCenter - center);
        if (distance < closestDistance) {
          closestDistance = distance;
          closestSection = section;
        }
      });

      if (closestSection && currentEra) {
        const era = (closestSection as HTMLElement).dataset.era || '';
        const eraText = document.getElementById('current-era-text');
        if (eraText && eraText.textContent !== era) {
          currentEra.style.opacity = '0';
          setTimeout(() => {
            eraText.textContent = era;
            currentEra.style.opacity = '1';
          }, 200);
        }
        // Highlight active item in dropdown
        document.querySelectorAll('.era-dropdown-item').forEach(item => {
          item.classList.toggle('active', (item as HTMLElement).dataset.era === era);
        });
      }
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      {
        root: container,
        threshold: 0.2,
        rootMargin: '0px 0px 0px -50px'
      }
    );

    document.querySelectorAll('.scroll-reveal').forEach((el) => {
      observer.observe(el);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') container.scrollLeft += 300;
      if (e.key === 'ArrowLeft') container.scrollLeft -= 300;
      if (e.key === 'Escape') closeDropdown();
    });

    // Era dropdown
    const dropdown = document.getElementById('era-dropdown');
    let dropdownOpen = false;

    function openDropdown() {
      if (!dropdown) return;
      dropdown.style.display = 'block';
      dropdownOpen = true;
      // Scroll active item into view
      const active = dropdown.querySelector('.active');
      if (active) active.scrollIntoView({ block: 'center' });
    }

    function closeDropdown() {
      if (!dropdown) return;
      dropdown.style.display = 'none';
      dropdownOpen = false;
    }

    currentEra?.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdownOpen ? closeDropdown() : openDropdown();
    });

    document.addEventListener('click', (e) => {
      if (dropdownOpen && dropdown && !dropdown.contains(e.target as Node)) {
        closeDropdown();
      }
    });

    document.querySelectorAll('.era-dropdown-item').forEach(item => {
      item.addEventListener('click', () => {
        const era = (item as HTMLElement).dataset.era;
        const section = document.querySelector(`.dynasty-section[data-era="${era}"]`);
        if (section && container) {
          const sectionRect = section.getBoundingClientRect();
          const containerRect = container.getBoundingClientRect();
          const offset = sectionRect.left - containerRect.left + container.scrollLeft - containerRect.width / 2 + sectionRect.width / 2;
          container.scrollTo({ left: offset, behavior: 'smooth' });
        }
        closeDropdown();
      });
    });

    // Scroll to dynasty if URL has a hash (e.g. #beisong), otherwise restore last position
    const hash = window.location.hash.slice(1);
    if (hash) {
      const target = document.querySelector(`.dynasty-section[data-slug="${hash}"]`);
      if (target) {
        requestAnimationFrame(() => {
          const rect = target.getBoundingClientRect();
          const containerRect = container.getBoundingClientRect();
          container.scrollLeft = rect.left - containerRect.left + container.scrollLeft - containerRect.width / 2 + rect.width / 2;
          target.classList.add('visible');
        });
      }
    } else {
      const saved = sessionStorage.getItem('scroll-pos');
      if (saved) {
        requestAnimationFrame(() => { container.scrollLeft = parseInt(saved); });
      }
    }
  }
</script>
